# ════════════════════════════════════════════════════════════════════════════
#  SAFUU ሳፉ — SECURITY-FIRST ENVIRONMENT CONFIGURATION
#  Generate all secrets before deploying. NEVER commit this file.
#
#  GENERATE SECRETS:
#  openssl rand -hex 32    → 64-char hex key
#  openssl rand -base64 32 → 44-char base64 key
# ════════════════════════════════════════════════════════════════════════════

# ── TELEGRAM ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
ADMIN_CHANNEL_ID=-1001234567890
# Set this in BotFather → API → Secret Token (used for webhook auth):
TELEGRAM_WEBHOOK_SECRET=generate_with_openssl_rand_hex_32

# ── AI SERVICES ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your_key_here
OPENAI_API_KEY=sk-your_openai_key
HIVE_AI_KEY=your_hive_key_here

# ── ENCRYPTION (MOST CRITICAL) ────────────────────────────────────────────────
# Master encryption key for AES-256-GCM at-rest encryption
# Generate: openssl rand -hex 32
# CHANGING THIS INVALIDATES ALL ENCRYPTED DATA — back up before changing
ENCRYPTION_MASTER_KEY=generate_64_char_hex_here

# KDF salt — used in key derivation, change before first run
ENCRYPTION_SALT=safuu_ethiopia_kdf_salt_change_this_to_something_unique

# ── DEDUPLICATION ─────────────────────────────────────────────────────────────
# Salt for one-way hashing of reporter identity
# Generate: openssl rand -hex 32
# CHANGING THIS means existing dedup hashes won't match — reporters can re-submit
DEDUP_SALT=safuu_ethiopia_dedup_change_this_to_something_unique_2025

# ── API / DASHBOARD AUTH ──────────────────────────────────────────────────────
# Dashboard API key (used for service-to-service calls)
# Generate: openssl rand -hex 32
DASHBOARD_API_KEY=generate_with_openssl_rand_hex_32

# JWT secret for dashboard user authentication
# Generate: openssl rand -hex 32
JWT_SECRET=generate_with_openssl_rand_hex_32

# Dashboard admin password (hashed with SHA-256 at comparison, never stored)
# Recommend using a strong password manager-generated password
ADMIN_PASSWORD=use_a_strong_password_min_20_chars

# Allowed dashboard origin (CORS)
DASHBOARD_ORIGIN=https://yourdomain.com

# ── API SERVER ────────────────────────────────────────────────────────────────
API_PORT=3001

# ── SMS (AFRICA'S TALKING) ────────────────────────────────────────────────────
AT_API_KEY=your_africastalking_api_key
AT_USERNAME=safuu
AT_SMS_FROM=SAFUU
AT_WEBHOOK_SECRET=generate_with_openssl_rand_hex_32
SMS_PORT=3002

# ── EMAIL (FEACC ROUTING) ─────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
# Use Gmail App Password: myaccount.google.com/apppasswords
SMTP_PASS=xxxx_xxxx_xxxx_xxxx
FEACC_EMAIL=contact@feaccdars.gov.et
ATTORNEY_GENERAL_EMAIL=

# ════════════════════════════════════════════════════════════════════════════
#  PRE-DEPLOYMENT SECURITY CHECKLIST
# ════════════════════════════════════════════════════════════════════════════
#
#  SECRETS & KEYS
#  [ ] All secrets generated with: openssl rand -hex 32
#  [ ] ENCRYPTION_MASTER_KEY is 64+ chars and backed up securely
#  [ ] DEDUP_SALT is unique and secret
#  [ ] JWT_SECRET is 64+ chars
#  [ ] DASHBOARD_API_KEY is 64+ chars
#  [ ] ADMIN_PASSWORD is 20+ chars, not reused
#  [ ] .env is in .gitignore (verified: git check-ignore .env)
#  [ ] No secrets in code comments, commit messages, or logs
#
#  SERVER & NETWORK
#  [ ] VPS has encrypted disk volume (DigitalOcean: enable block storage encryption)
#  [ ] UFW firewall: only ports 22, 80, 443 exposed (3001/3002 localhost only)
#        sudo ufw allow 22 && sudo ufw allow 80 && sudo ufw allow 443 && sudo ufw enable
#  [ ] SSH key-only auth (password SSH disabled)
#        /etc/ssh/sshd_config: PasswordAuthentication no
#  [ ] SSH on non-standard port (optional)
#  [ ] Fail2ban installed for SSH brute force protection
#        sudo apt install fail2ban
#  [ ] Automatic security updates enabled
#        sudo apt install unattended-upgrades && sudo dpkg-reconfigure unattended-upgrades
#
#  NGINX & TLS
#  [ ] TLS cert from Certbot (Let's Encrypt): certbot --nginx -d yourdomain.com
#  [ ] DH params generated: openssl dhparam -out /etc/nginx/dhparam.pem 4096
#  [ ] SSL Labs test: A+ rating at https://www.ssllabs.com/ssltest/
#  [ ] HSTS preload submitted to https://hstspreload.org
#  [ ] Nginx server_tokens off (verify: curl -I https://yourdomain.com)
#
#  DATABASE
#  [ ] SQLite files on encrypted volume
#  [ ] DB file permissions: chmod 600 ./data/safuu.db
#  [ ] Automated daily backup (encrypted):
#        sqlite3 safuu.db ".backup backup_$(date +%Y%m%d).db"
#        openssl enc -aes-256-cbc -in backup_*.db -out backup_*.db.enc -k $BACKUP_PASS
#  [ ] Backup stored off-server (S3 or encrypted external)
#
#  APPLICATION
#  [ ] Node.js version ≥ 18 LTS
#  [ ] npm audit run: npm audit --audit-level=high
#  [ ] All deps pinned to exact versions in package.json
#  [ ] Process running as non-root user (e.g. 'safuu' system user)
#        adduser --system --group safuu
#        chown -R safuu:safuu /opt/safuu
#  [ ] PM2 running as safuu user, not root
#  [ ] File permissions: chmod 700 /opt/safuu/data
#
#  TELEGRAM BOT
#  [ ] Bot running in webhook mode (not polling) in production
#  [ ] Webhook URL set: TELEGRAM_BOT_TOKEN/setWebhook?url=https://yourdomain.com/telegram/webhook
#  [ ] Webhook secret set in BotFather (matches TELEGRAM_WEBHOOK_SECRET)
#  [ ] Bot profile photo and description set (builds trust with reporters)
#  [ ] Bot privacy mode: /setprivacy → enabled (bot only sees messages starting with /)
#
#  MONITORING & INCIDENT RESPONSE
#  [ ] PM2 monitoring: pm2 monitor
#  [ ] Uptime monitoring: UptimeRobot free tier (https://uptimerobot.com)
#  [ ] Error alerts: PM2 → Telegram on crash (pm2-telegram-notifier)
#  [ ] Log rotation configured: /etc/logrotate.d/safuu
#  [ ] Incident response plan documented (who to notify if breach suspected)
#  [ ] Backup admin Telegram handle noted for emergencies
#
#  DATA & PRIVACY
#  [ ] Confirmed: no user_id, username, phone stored in reports table
#  [ ] Confirmed: audit log contains no PII
#  [ ] Confirmed: dedup hashes are one-way (tested: cannot reverse to user_id)
#  [ ] Confirmed: voice files deleted immediately after transcription
#  [ ] Confirmed: temp image files deleted after forensic processing
#  [ ] Data retention policy documented and enforced
#
#  FEACC INTEGRATION
#  [ ] FEACC email contact confirmed and tested
#  [ ] Test email sent and received before go-live
#  [ ] Email sending domain has SPF, DKIM, DMARC records configured
#
# ════════════════════════════════════════════════════════════════════════════
#  PM2 DEPLOYMENT COMMANDS
# ════════════════════════════════════════════════════════════════════════════
#
#  Install PM2:
#    npm install -g pm2
#
#  Start all services:
#    pm2 start safuu-bot.js              --name safuu-bot    --user safuu
#    pm2 start safuu-server-secure.js    --name safuu-api    --user safuu
#    pm2 start safuu-sms.js              --name safuu-sms    --user safuu
#    pm2 save
#    pm2 startup
#
#  Monitor:
#    pm2 status
#    pm2 logs safuu-bot --lines 50
#    pm2 monit
#
#  Zero-downtime restart:
#    pm2 reload all
#
# ════════════════════════════════════════════════════════════════════════════
